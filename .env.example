# .env.example – Copy this to .env and fill in your values
# cp .env.example .env

#  Endee Vector Database
ENDEE_HOST=http://localhost:8080
# ENDEE_AUTH_TOKEN=               # Uncomment if you set NDD_AUTH_TOKEN on the server

# Index Settings 
INDEX_NAME=sourya_rag
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DIM=384

# ── Chunking 
CHUNK_SIZE=200
CHUNK_OVERLAP=40

# ── Retrieval 
TOP_K=5
RERANK_TOP_N=3

# LLM Provider (choose one)
# Option A: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini

# Option B: Google Gemini
LLM_PROVIDER=google
GOOGLE_API_KEY=AIzaSyCeIoGYw2SeejJxdT8ZMxTe__XmLmby2AE
GOOGLE_MODEL=gemini-3-flash-preview

# Option C: Ollama (local, free)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# App
APP_PORT=7860
DEBUG=false
